# ==============================================================
# Variáveis de ambiente — copie para .env.local e preencha.
# NUNCA commite valores reais. Ver specs/17-security.md.
# ==============================================================

# --- Supabase ---
# URL do projeto (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_...) — segura para o cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key (sb_secret_...) — SOMENTE server-side; contorna RLS
SUPABASE_SERVICE_ROLE_KEY=
# Ref/ID do projeto (usado pela CLI do Supabase)
SUPABASE_PROJECT_ID=
# Connection string do Postgres (Dashboard > Settings > Database) — usada pelo Drizzle
# Formato: postgresql://postgres.<project_ref>:<SENHA_DO_BANCO>@aws-0-<regiao>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- Groq (IA — specs/13-ai-groq.md) ---
# SOMENTE server-side
GROQ_API_KEY=

# --- Google Places (descoberta — specs/08-business-discovery.md) ---
# SOMENTE server-side; restrinja a chave à Places API no Google Cloud Console
GOOGLE_PLACES_API_KEY=
