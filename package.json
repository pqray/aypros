{
  "name": "aypros",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:all": "turbo run dev",
    "start": "pnpm start:web",
    "start:web": "pnpm --dir apps/web start",
    "start:api": "pnpm --dir apps/api start",
    "docker:api:build": "docker compose -f docker-compose.api.yml build api",
    "docker:api:up": "docker compose -f docker-compose.api.yml up -d api",
    "docker:api:down": "docker compose -f docker-compose.api.yml down",
    "docker:api:logs": "docker compose -f docker-compose.api.yml logs -f api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  }
}
